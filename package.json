{
  "name": "ringcentral-code-generator",
  "version": "0.8.0",
  "license": "MIT",
  "type": "module",
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.types.json",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "tsx -r dotenv-override-true/config src/test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/ramda": "^0.32.0",
    "change-case": "5.4.4",
    "js-yaml": "^5.1.0",
    "openapi-types": "^12.1.3",
    "ramda": "^0.32.0",
    "ringcentral-open-api-parser": "link:../ringcentral-open-api-parser"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "dotenv-override-true": "^6.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.9.0"
}
